# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# Supabase — https://supabase.com/dashboard/project/<ref>/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Agora RTC — https://console.agora.io
AGORA_APP_ID=YOUR_AGORA_APP_ID

# Tap Payments — https://www.tap.company
# Secret key goes in Supabase Edge Function secrets (never in the app):
#   supabase secrets set TAP_SECRET_KEY=sk_live_...
TAP_REDIRECT_DOMAIN=https://YOUR_DOMAIN
